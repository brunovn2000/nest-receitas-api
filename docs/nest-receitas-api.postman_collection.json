{
  "info": {
    "name": "Nest Receitas API",
    "_postman_id": "9d68d84a-7bb5-4f95-a2f8-0f7e7a5d4b21",
    "description": "Collection para autenticacao e receitas.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Users - Criar",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nome\": \"Usuario Teste\",\n  \"login\": \"{{login}}\",\n  \"senha\": \"{{senha}}\"\n}"
        },
        "url": "{{baseUrl}}/users"
      }
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"login\": \"{{login}}\",\n  \"senha\": \"{{senha}}\"\n}"
        },
        "url": "{{baseUrl}}/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const data = pm.response.json();",
              "if (data && data.access_token) {",
              "  pm.environment.set('accessToken', data.access_token);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth - Me",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/auth/me"
      }
    },
    {
      "name": "Auth - Logout",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/auth/logout"
      }
    },
    {
      "name": "Categories - Listar",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/categories"
      }
    },
    {
      "name": "Recipes - Listar",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/recipes"
      }
    },
    {
      "name": "Recipes - Criar",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "categoryId",
              "value": "1",
              "type": "text"
            },
            {
              "key": "nome",
              "value": "Bolo de Cenoura",
              "type": "text"
            },
            {
              "key": "tempoPreparoMinutos",
              "value": "45",
              "type": "text"
            },
            {
              "key": "porcoes",
              "value": "8",
              "type": "text"
            },
            {
              "key": "modoPreparo",
              "value": "Misture os ingredientes e asse.",
              "type": "text"
            },
            {
              "key": "ingredientes",
              "value": "cenoura, farinha, ovos, acucar",
              "type": "text"
            },
            {
              "key": "imagem",
              "type": "file",
              "src": []
            }
          ]
        },
        "url": "{{baseUrl}}/recipes"
      }
    },
    {
      "name": "Recipes - Buscar por ID",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/recipes/{{recipeId}}"
      }
    },
    {
      "name": "Recipes - Atualizar",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "nome",
              "value": "Bolo de Cenoura com Cobertura",
              "type": "text"
            },
            {
              "key": "imagem",
              "type": "file",
              "src": []
            }
          ]
        },
        "url": "{{baseUrl}}/recipes/{{recipeId}}"
      }
    },
    {
      "name": "Recipes - Remover",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/recipes/{{recipeId}}"
      }
    },
    {
      "name": "Recipes - Imprimir",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/recipes/{{recipeId}}/print"
      }
    }
  ]
}
